---
interface Props {
  type?: "website" | "article" | "profile" | undefined;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  /** og:site_name value. */
  siteName: string;
  /** og:locale value. Defaults to "ja_JP". */
  locale?: string | undefined;
  descriptionMaxLength?: number | undefined;
  ellipsis?: boolean | undefined;
  /**
   * "https-only" emits og:image:secure_url only for https images;
   * "always" emits it unconditionally. Defaults to "https-only".
   */
  secureUrlMode?: "always" | "https-only" | undefined;
  article?:
    | {
        publishedTime?: string | undefined;
        modifiedTime?: string | undefined;
        authors?: string[] | undefined;
        section?: string | undefined;
        tags?: string[] | undefined;
      }
    | undefined;
}

const {
  type = "website",
  title,
  description,
  image,
  imageAlt,
  siteName,
  locale = "ja_JP",
  descriptionMaxLength = 200,
  ellipsis = false,
  secureUrlMode = "https-only",
  article,
} = Astro.props;

const resolvedDescription =
  ellipsis && description.length > descriptionMaxLength
    ? `${description.slice(0, descriptionMaxLength - 3)}...`
    : description.slice(0, descriptionMaxLength);
const ogUrl = new URL(Astro.url.pathname, Astro.site).href;
const secureUrl =
  secureUrlMode === "always"
    ? image
    : image.startsWith("https://")
      ? image
      : undefined;
---

<meta property="og:type" content={type} />
<meta property="og:url" content={ogUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:image" content={image} />
{secureUrl && <meta property="og:image:secure_url" content={secureUrl} />}
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />
{type === "article" && article?.publishedTime && (
  <meta property="article:published_time" content={article.publishedTime} />
)}
{type === "article" && article?.modifiedTime && (
  <meta property="article:modified_time" content={article.modifiedTime} />
)}
{type === "article" && article?.authors?.map((author) => (
  <meta property="article:author" content={author} />
))}
{type === "article" && article?.section && (
  <meta property="article:section" content={article.section} />
)}
{type === "article" && article?.tags?.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
