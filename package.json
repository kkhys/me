{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "all": "pnpm build && pnpm check && pnpm lint:fix && pnpm test && pnpm coverage",
    "deploy": "pnpm build && wrangler pages deploy dist",
    "release": "bun run scripts/release.ts",
    "convert-videos": "bun run scripts/convert-videos.ts"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "0.2.0",
    "astro": "6.3.5",
    "kiso.css": "1.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.2",
    "@biomejs/biome": "2.4.15",
    "@playform/compress": "0.2.3",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.15",
    "@vitest/coverage-v8": "4.1.7",
    "react": "19.2.6",
    "satori": "0.26.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.93.0"
  }
}
