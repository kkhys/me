    "astro": "6.3.3",
    "kiso.css": "1.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "typescript": "6.0.3",
    "wrangler": "4.92.0"
  }
}
