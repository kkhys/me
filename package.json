{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "all": "pnpm build && pnpm check && pnpm lint:fix && pnpm test && pnpm coverage",
    "vercel-install": "scripts/vercel-submodule-workaround.sh && pnpm install"
  },
  "dependencies": {
    "astro": "5.16.2",
    "kiso.css": "1.2.2",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@biomejs/biome": "2.3.8",
    "@types/mdast": "4.0.4",
    "@vitest/coverage-v8": "4.0.14",
    "mdast-util-to-string": "4.0.0",
    "remark": "15.0.1",
    "typescript": "5.9.3",
    "vitest": "4.0.14"
  },
  "packageManager": "pnpm@10.23.0",
  "volta": {
    "node": "24.11.1"
  }
}
