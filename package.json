{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "all": "pnpm build && pnpm check && pnpm lint:fix",
    "vercel-install": "scripts/vercel-submodule-workaround.sh && pnpm install",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@astrojs/partytown": "2.1.4",
    "astro": "5.16.6",
    "kiso.css": "1.2.3",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/sitemap": "3.6.0",
    "@biomejs/biome": "2.3.10",
    "@playform/compress": "0.2.0",
    "@types/bun": "1.3.5",
    "@types/react": "19.2.7",
    "react": "19.2.3",
    "satori": "0.18.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.27.0",
  "volta": {
    "node": "24.12.0"
  }
}
