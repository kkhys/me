{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "kkhys",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "coverage": "pnpm -r coverage",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "build:me": "pnpm --filter @kkhys/me build",
    "dev:me": "pnpm --filter @kkhys/me dev",
    "deploy:me": "pnpm --filter @kkhys/me deploy",
    "build:lgtm": "pnpm --filter @kkhys/lgtm build",
    "dev:lgtm": "pnpm --filter @kkhys/lgtm dev",
    "deploy:lgtm": "pnpm --filter @kkhys/lgtm deploy",
    "build:diary": "pnpm --filter @kkhys/diary build",
    "dev:diary": "pnpm --filter @kkhys/diary dev",
    "deploy:diary": "pnpm --filter @kkhys/diary deploy",
    "dev:memo": "pnpm --filter @kkhys/memo dev",
    "dev:studio": "pnpm --filter @kkhys/studio dev",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@kkhys/release": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  }
}
