{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "all": "pnpm build && pnpm check && pnpm lint:fix && pnpm test && pnpm coverage",
    "release": "bun run scripts/release.ts",
    "sync-submodule": "gh workflow run sync-submodule.yml"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "0.1.6",
    "astro": "6.0.8",
    "kiso.css": "1.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/sitemap": "3.7.1",
    "@biomejs/biome": "2.4.9",
    "@playform/compress": "0.2.2",
    "@types/bun": "1.3.11",
    "@types/mdast": "4.0.4",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "4.1.1",
    "fetch-site-metadata": "0.2.0",
    "mdast-util-to-string": "4.0.0",
    "react": "19.2.4",
    "rehype-external-links": "3.0.0",
    "remark": "15.0.1",
    "satori": "0.26.0",
    "typescript": "5.9.3",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "vitest": "4.1.1",
    "wrangler": "4.77.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd"
    ]
  }
}
