---
import TwitterCard from "@kkhys/seo/twitter-card.astro";
import { me } from "#/config/site";

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
}

const { title, description, image, imageAlt } = Astro.props;
---

<TwitterCard
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  site={me.twitter}
/>
