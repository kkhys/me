{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@kkhys/me",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "all": "pnpm build && pnpm check && pnpm lint:fix && pnpm test && pnpm coverage",
    "playwright-install": "pnpm dlx playwright-core install chromium",
    "render:mermaid": "bun run scripts/render-mermaid.ts",
    "create:entry": "bun run scripts/create-entry.ts",
    "deploy": "pnpm build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/check": "catalog:",
    "@astrojs/compiler-rs": "catalog:",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/react": "catalog:",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "catalog:",
    "@justinribeiro/lite-youtube": "1.9.0",
    "@kkhys/og": "workspace:*",
    "@kkhys/seo": "workspace:*",
    "@kkhys/styles": "workspace:*",
    "astro": "catalog:",
    "astro-expressive-code": "0.44.0",
    "graphql-request": "7.4.0",
    "kiso.css": "catalog:",
    "sharp": "catalog:"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "catalog:",
    "@expressive-code/plugin-line-numbers": "0.44.0",
    "@types/bun": "catalog:",
    "@types/hast": "3.0.4",
    "@types/mdast": "catalog:",
    "@types/react": "catalog:",
    "@types/unist": "3.0.3",
    "@vitest/coverage-v8": "catalog:",
    "bech32": "2.0.0",
    "budoux": "0.8.4",
    "fetch-site-metadata": "catalog:",
    "hast-util-from-html": "2.0.3",
    "hast-util-to-html": "9.0.5",
    "linkedom": "0.18.12",
    "mdast-util-mdx-jsx": "3.2.0",
    "mermaid-isomorphic": "3.1.0",
    "mini-svg-data-uri": "1.4.4",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "1.61.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rehype-slug": "6.0.0",
    "satori": "catalog:",
    "schema-dts": "2.0.0",
    "typescript": "catalog:",
    "unist-util-visit": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
