---
import "#/styles/global.css";

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: { src: string; width: number; height: number } | undefined;
}

const {
  title = "Keisuke Hayashi Diary",
  description = "Photo diary by kkhys",
  image,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/index\.html$/, "");
const canonicalUrl = new URL(pathname, Astro.site).href;
const ogImageUrl = image ? new URL(image.src, Astro.site).href : undefined;
---

<html lang="ja">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="generator" content={Astro.generator}/>
  <link rel="canonical" href={canonicalUrl}/>
  <link rel="sitemap" href="/sitemap-index.xml"/>

  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonicalUrl}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:site_name" content="Keisuke Hayashi Diary"/>
  <meta property="og:locale" content="ja_JP"/>
  {ogImageUrl && image && (
    <>
      <meta property="og:image" content={ogImageUrl}/>
      <meta property="og:image:width" content={String(image.width)}/>
      <meta property="og:image:height" content={String(image.height)}/>
      <meta property="og:image:alt" content={title}/>
    </>
  )}

  <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"}/>
  <meta name="twitter:site" content="@kkhys_"/>
  <meta name="twitter:creator" content="@kkhys_"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  {ogImageUrl && (
    <>
      <meta name="twitter:image" content={ogImageUrl}/>
      <meta name="twitter:image:alt" content={title}/>
    </>
  )}

  <noscript>
    <style>
      .blur-load { filter: none !important; background: none !important; }
    </style>
  </noscript>
</head>
<body>
<main>
  <slot/>
</main>
</body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-block-size: 100dvh;
    margin: 0;
  }

  main {
    flex: 1;
    inline-size: 100%;
    max-inline-size: 1440px;
    margin-inline: auto;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  @media (width >= 768px) {
    main {
      inline-size: min(100% - 5rem, 1440px);
    }
  }
</style>
