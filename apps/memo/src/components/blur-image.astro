---
import { getImage, Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;

const blurryImage = await getImage({ src, width: 20 });
---

<div class="blur-load-wrapper">
  <div class="blur-load" data-blur-load>
    <Picture
      src={src}
      alt={alt}
      formats={['avif']}
      widths={[320, 640, 1280]}
      sizes="(min-width: 640px) 640px, 100vw"
      onload="this.closest('[data-blur-load]')?.classList.add('image-loaded')"
    />
  </div>
</div>

<style define:vars={{ 'bg-image': `url(${blurryImage.src})`, 'aspect-ratio': `${src.width} / ${src.height}` }}>
  .blur-load-wrapper {
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 0 0 1px var(--c-gray);
    aspect-ratio: var(--aspect-ratio);
  }

  .blur-load {
    background: var(--bg-image) center / cover no-repeat;
    filter: blur(36px);
    transition: filter 250ms ease-in-out;
  }

  .blur-load.image-loaded {
    background: none;
    filter: none;
  }

  .blur-load :global(picture) {
    display: block;
  }

  .blur-load :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
