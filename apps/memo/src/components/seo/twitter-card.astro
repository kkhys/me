---
import { TWITTER_ACCOUNT_NAME } from "#/config/constants";

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
}

const { title, description, image, imageAlt = title } = Astro.props;

const truncatedDescription =
  description.length > 200 ? `${description.slice(0, 197)}...` : description;
---

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={TWITTER_ACCOUNT_NAME} />
<meta name="twitter:creator" content={TWITTER_ACCOUNT_NAME} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={truncatedDescription} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={imageAlt} />
