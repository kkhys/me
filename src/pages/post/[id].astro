---
import type { GetStaticPaths } from "astro";
import Feed from "#/components/feed.astro";
import ThreadPost from "#/components/thread-post.astro";
import { TITLE } from "#/config/constants";
import Layout from "#/layouts/layout.astro";
import { getPublishedMemos } from "#/utils/memo";

export const getStaticPaths = (async () =>
  (await getPublishedMemos()).map((memo) => {
    return {
      params: {
        id: memo.data.id,
      },
      props: {
        memo,
      },
    };
  })) satisfies GetStaticPaths;

const { memo } = Astro.props;
---

<Layout title={`Thread | ${TITLE}`}>
    <Feed>
        <ThreadPost memo={memo} asLink={false} shouldUsePriority />
    </Feed>
</Layout>
