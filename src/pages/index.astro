---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import CheckIcon from "#/components/icon/check-icon.astro";
import CopyIcon from "#/components/icon/copy-icon.astro";
import BaseSeo from "#/components/seo/base-seo.astro";
import JsonLd from "#/components/seo/json-ld.astro";
import OpenGraph from "#/components/seo/open-graph.astro";
import TwitterCard from "#/components/seo/twitter-card.astro";
import { TITLE } from "#/config/constants";
import Layout from "#/layouts/layout.astro";

function shuffleArray<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    const temp = shuffled[i] as T;
    shuffled[i] = shuffled[j] as T;
    shuffled[j] = temp;
  }
  return shuffled;
}

const lgtmEntries = shuffleArray(
  (await getCollection("lgtm")).filter((entry) => !entry.data.isDraft),
);

const title = `${TITLE} by Keisuke Hayashi`;
const description =
  "A curated collection of LGTM images for GitHub Pull Requests. Perfect for code reviews and approvals.";
const ogImageUrl = new URL("/api/og/default.png", Astro.site).href;
---

<Layout>
  <BaseSeo slot="seo" title={title} description={description} />
  <OpenGraph
    slot="seo"
    title={title}
    description={description}
    image={ogImageUrl}
    imageAlt="LGTM Image Collection"
    type="website"
  />
  <TwitterCard
    slot="seo"
    title={title}
    description={description}
    image={ogImageUrl}
    imageAlt="LGTM Image Collection"
  />
  <JsonLd
    slot="structured-data"
    type="WebSite"
    data={{
      name: TITLE,
      description: description,
      url: Astro.site?.href,
      inLanguage: "en-US",
    }}
  />
  <div class="container">
    <div class="lgtm-grid">
      {
        lgtmEntries.map((entry) => (
          <article class="lgtm-item">
            <a href={`/${entry.id}`} class="lgtm-link">
              <Picture
                src={`/${entry.id}-1000.png`}
                formats={["avif", "webp"]}
                alt="LGTM Image"
                width={515}
                height={343}
                densities={[1, 2]}
                class="lgtm-image"
              />
            </a>
            <button
              class="copy-button"
              data-id={entry.id}
              title="Copy Markdown"
              aria-label="Copy Markdown"
            >
              <CopyIcon class="copy-icon" />
              <CheckIcon class="check-icon" />
            </button>
          </article>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .lgtm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    max-width: 100%;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .lgtm-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .lgtm-item {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 0.5rem;
    background-color: var(--c-bg-image);
  }

  .copy-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.25rem;
    background-color: var(--c-bg);
    color: var(--c-text-emphasis);
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 1;
  }

  .lgtm-item:hover .copy-button {
    opacity: 1;
  }

  .copy-button:hover {
    background-color: var(--c-bg-hover);
    color: var(--c-text);
  }

  .copy-button:active {
    transform: scale(0.9);
  }

  .copy-button svg {
    transition: opacity 0.1s ease;
  }

  .copy-button.copied {
    border: 1px solid var(--c-text-emphasis);
  }

  .copy-button.copied .copy-icon {
    opacity: 0;
  }

  .copy-button .check-icon {
    position: absolute;
    opacity: 0;
    transition: opacity 0.1s ease;
  }

  .copy-button.copied .check-icon {
    opacity: 1;
  }

  .lgtm-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .lgtm-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .lgtm-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .copy-button {
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .lgtm-grid {
      grid-template-columns: 1fr;
    }

    .container {
      padding: 1.5rem 1rem;
    }

    .copy-button {
      opacity: 1;
    }

    .page-description {
      margin-bottom: 2rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const copyButtons = document.querySelectorAll(".copy-button");

    copyButtons.forEach((button) => {
      button.addEventListener("click", async (e) => {
        e.preventDefault();
        e.stopPropagation();

        const id = (button as HTMLElement).dataset.id;
        if (!id) return;

        const markdown = `[![LGTM!!](https://lgtm.kkhys.me/${id}.avif)](https://lgtm.kkhys.me/${id})`;

        try {
          await navigator.clipboard.writeText(markdown);
          button.classList.add("copied");
          setTimeout(() => {
            button.classList.remove("copied");
          }, 1000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });
    });
  });
</script>
