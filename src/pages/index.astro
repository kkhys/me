---
import Feed from "#/components/feed.astro";
import ThreadPost from "#/components/thread-post.astro";
import { TITLE } from "#/config/constants";
import Layout from "#/layouts/layout.astro";
import { getMemosWithComments } from "#/utils/memo";

const memosWithComments = await getMemosWithComments();
---

<Layout title={TITLE}>
    <Feed>
        {
            memosWithComments.map(({ main, comments }, index) => (
                <ThreadPost
                    memo={main}
                    comments={comments}
                    shouldUsePriority={index < 6}
                />
            ))
        }
    </Feed>
</Layout>
