---
import { Picture } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import ArrowLeftIcon from "#/components/icon/arrow-left-icon.astro";
import CheckIcon from "#/components/icon/check-icon.astro";
import BaseSeo from "#/components/seo/base-seo.astro";
import JsonLd from "#/components/seo/json-ld.astro";
import OpenGraph from "#/components/seo/open-graph.astro";
import TwitterCard from "#/components/seo/twitter-card.astro";
import { TITLE } from "#/config/constants";
import Layout from "#/layouts/layout.astro";

export const getStaticPaths = async () => {
  const lgtmEntries = await getCollection("lgtm");
  return lgtmEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
};

type Props = {
  entry: CollectionEntry<"lgtm">;
};

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/404");
}

const title = `LGTM Image - ${TITLE}`;
const description = "Perfect LGTM image for your GitHub Pull Request reviews.";
const ogImageUrl = new URL('/api/og/default.png', Astro.site).href;
---

<Layout>
  <BaseSeo slot="seo" title={title} description={description} />
  <OpenGraph
    slot="seo"
    title={title}
    description={description}
    image={ogImageUrl}
    imageAlt="LGTM Image"
    type="article"
  />
  <TwitterCard
    slot="seo"
    title={title}
    description={description}
    image={ogImageUrl}
    imageAlt="LGTM Image"
  />
  <JsonLd
    slot="structured-data"
    type="Article"
    data={{
      headline: title,
      description: description,
      url: `/${id}`,
      inLanguage: "en-US",
    }}
  />

  <div class="container">
    <div class="detail-wrapper">
      <div class="image-container">
        <Picture
          src={`/${id}-1200.png`}
          formats={["avif", "webp"]}
          alt="LGTM Image"
          width={1200}
          height={800}
          densities={[1, 2]}
          loading="eager"
          class="detail-image"
        />
      </div>

      <div class="info-bar">
        <div class="actions">
          <div class="copy-buttons">
            <button class="copy-format-button" data-id={id} data-format="avif">
              <span class="button-text">AVIF</span>
              <CheckIcon class="check-icon" />
            </button>
            <button class="copy-format-button" data-id={id} data-format="webp">
              <span class="button-text">WebP</span>
              <CheckIcon class="check-icon" />
            </button>
            <button class="copy-format-button" data-id={id} data-format="png">
              <span class="button-text">PNG</span>
              <CheckIcon class="check-icon" />
            </button>
          </div>

          <a
            href="/"
            class="icon-button"
            title="Back to gallery"
            aria-label="Back to gallery"
          >
            <ArrowLeftIcon />
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    width: 100%;
    box-sizing: border-box;
  }

  .detail-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .image-container {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--c-bg-image);
    transition: transform 0.1s ease;
    cursor: pointer;
  }

  .image-container:active {
    transform: scale(0.99);
  }

  .detail-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .info-bar {
    padding: 0.5rem 0;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .copy-buttons {
    display: flex;
    gap: 0.25rem;
  }

  .copy-format-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-family: "SF Mono", "Monaco", "Inconsolata", "Fira Code", monospace;
    border: 1px solid var(--c-border);
    border-radius: 0.25rem;
    background-color: transparent;
    color: var(--c-text-secondary);
    cursor: pointer;
    transition: all 0.1s ease;
  }

  .copy-format-button:hover {
    border-color: var(--c-text-secondary);
    background-color: var(--c-bg-hover);
    color: var(--c-text);
  }

  .copy-format-button:active {
    transform: scale(0.95);
  }

  .copy-format-button.copied {
    border-color: var(--c-text-emphasis);
  }

  .copy-format-button .button-text {
    transition: opacity 0.1s ease;
  }

  .copy-format-button.copied .button-text {
    opacity: 0;
  }

  .copy-format-button .check-icon {
    position: absolute;
    width: 0.875rem;
    height: 0.875rem;
    opacity: 0;
    transition: opacity 0.1s ease;
  }

  .copy-format-button.copied .check-icon {
    opacity: 1;
  }

  .icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.25rem;
    color: var(--c-text-emphasis);
    transition: all 0.1s ease;
    text-decoration: none;
    border: none;
    background-color: transparent;
    cursor: pointer;
  }

  .icon-button:hover {
    background-color: var(--c-bg-hover);
    color: var(--c-text);
  }

  .icon-button:active {
    transform: scale(0.9);
  }

  @media (max-width: 768px) {
    .container {
      padding: 1rem;
    }

    .detail-wrapper {
      gap: 0.75rem;
    }

    .image-container {
      border-radius: 0.375rem;
    }

    .info-bar {
      padding: 0.25rem 0;
    }

    .actions {
      gap: 0.5rem;
    }

    .copy-buttons {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.25rem;
    }

    .copy-format-button {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0.75rem;
    }

    .detail-wrapper {
      gap: 0.5rem;
    }

    .image-container {
      border-radius: 0.25rem;
    }

    .actions {
      gap: 0.5rem;
    }

    .copy-buttons {
      gap: 0.25rem;
    }

    .copy-format-button {
      font-size: 0.6875rem;
      padding: 0.25rem 0.375rem;
    }

    .icon-button {
      width: 1.75rem;
      height: 1.75rem;
    }

    .icon-button svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const copyButtons = document.querySelectorAll(".copy-format-button");

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const id = (button as HTMLElement).dataset.id;
        const format = (button as HTMLElement).dataset.format;
        if (!id || !format) return;

        const markdown = `[![LGTM!!](https://lgtm.kkhys.me/${id}.${format})](https://lgtm.kkhys.me/${id})`;

        try {
          await navigator.clipboard.writeText(markdown);
          button.classList.add("copied");
          setTimeout(() => {
            button.classList.remove("copied");
          }, 1000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });
    });
  });
</script>
