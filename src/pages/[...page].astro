---
import type { GetStaticPaths } from "astro";
import Feed from "#/components/feed.astro";
import Spinner from "#/components/spinner.astro";
import ThreadPost from "#/components/thread-post.astro";
import { PAGE_SIZE, TITLE } from "#/config/constants";
import Layout from "#/layouts/layout.astro";
import { getMemosWithComments } from "#/utils/memo";

export const getStaticPaths = (async ({ paginate }) => {
  const memosWithComments = await getMemosWithComments();

  return paginate(memosWithComments, {
    pageSize: PAGE_SIZE,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={TITLE}>
  <Feed
    id="memo-container"
    data-current-page={page.currentPage}
    data-total-pages={page.lastPage}
  >
    {
      page.data.map(({ main, comments }, index) => (
        <ThreadPost
          memo={main}
          comments={comments}
          shouldUsePriority={page.currentPage === 1 && index < 6}
        />
      ))
    }
  </Feed>

  {page.currentPage < page.lastPage && (
    <>
      <div id="scroll-trigger"></div>
      <div id="loading-indicator" class="loading-indicator hidden">
        <Spinner />
      </div>
    </>
  )}

  <script>
    const initInfiniteScroll = () => {
      const containerEl = document.getElementById("memo-container");
      const triggerEl = document.getElementById("scroll-trigger");
      const loadingIndicatorEl = document.getElementById("loading-indicator");

      if (!containerEl || !triggerEl || !loadingIndicatorEl) {
        return;
      }

      const container: HTMLElement = containerEl;
      const trigger: HTMLElement = triggerEl;
      const loadingIndicator: HTMLElement = loadingIndicatorEl;

      let currentPage = Number.parseInt(container.dataset.currentPage || "1", 10);
      const totalPages = Number.parseInt(container.dataset.totalPages || "1", 10);
      let isLoading = false;

      const showLoading = () => loadingIndicator.classList.remove("hidden");
      const hideLoading = () => loadingIndicator.classList.add("hidden");

      const showEndMessage = () => {
        trigger.remove();
        loadingIndicator.innerHTML = "You've reached the end 🎉";
        loadingIndicator.classList.remove("hidden");
      }

      const loadMoreMemos = async () => {
        const nextPage = currentPage + 1;

        if (nextPage > totalPages) {
          observer.unobserve(trigger);
          showEndMessage();
          return;
        }

        isLoading = true;
        showLoading();

        const startTime = Date.now();

        try {
          const url = nextPage === 1 ? "/" : `/${nextPage}`;
          const response = await fetch(url);

          if (!response.ok) {
            throw new Error(`Failed to fetch page ${nextPage}`);
          }

          const html = await response.text();

          const parser = new DOMParser();
          const doc = parser.parseFromString(html, "text/html");

          const nextContainer = doc.getElementById("memo-container");
          if (!nextContainer) {
            throw new Error("memo-container not found in fetched page");
          }

          const elapsed = Date.now() - startTime;
          const remainingTime = Math.max(0, 500 - elapsed);
          if (remainingTime > 0) {
            await new Promise((resolve) => setTimeout(resolve, remainingTime));
          }

          const memoCards = nextContainer.children;
          for (const card of Array.from(memoCards)) {
            container.appendChild(card);
          }

          currentPage = nextPage;

          if (currentPage >= totalPages) {
            observer.unobserve(trigger);
            hideLoading();
            showEndMessage();
          }
        } catch (error) {
          console.error("Failed to load more memos:", error);

          const elapsed = Date.now() - startTime;
          const remainingTime = Math.max(0, 1000 - elapsed);
          if (remainingTime > 0) {
            await new Promise((resolve) => setTimeout(resolve, remainingTime));
          }
        } finally {
          isLoading = false;
          if (currentPage < totalPages) {
            hideLoading();
          }
        }
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const firstEntry = entries[0];
          if (
            firstEntry &&
            firstEntry.isIntersecting &&
            !isLoading &&
            currentPage < totalPages
          ) {
            loadMoreMemos();
          }
        },
        { rootMargin: "200px" },
      );

      observer.observe(trigger);
    }

    initInfiniteScroll();
  </script>
</Layout>

<style>
  .loading-indicator {
    display: grid;
    place-items: center;
    padding: 2rem;
    font-size: var(--fs-xs);
  }

  .loading-indicator.hidden {
    display: none;
  }

  #scroll-trigger {
    height: 1px;
  }
</style>
