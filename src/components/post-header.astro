---
import type { InferEntrySchema } from "astro:content";
import { formatDate, formatDateTime } from "../utils/date";

interface Props
  extends Pick<InferEntrySchema<"memo">, "author" | "createdAt"> {}

const { author, createdAt } = Astro.props;
const createdAtString = formatDate(createdAt);
const fullDateTimeString = formatDateTime(createdAt);
---

<div class="post-header">
    <span class="post-username">{author}</span>
    <time class="post-time" datetime={createdAt.toISOString()} title={fullDateTimeString}
        >{createdAtString}</time
    >
</div>

<style>
    .post-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.15rem;
    }

    .post-username {
        font-size: var(--fs-xs);
        font-weight: var(--fw-semibold);
        color: var(--c-text);
    }

    .post-time {
        font-size: var(--fs-xs);
        color: var(--c-sub-text);
        font-variant-numeric: tabular-nums;
    }
</style>
