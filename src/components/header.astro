---
const currentPath = Astro.url.pathname;

const PATH_RULES = [
  { match: (p: string) => p === "/", getTitle: () => "Memo" },
  {
    match: (p: string) => p.startsWith("/tag/"),
    getTitle: (p: string) => {
      const tagName = p.replace("/tag/", "").replace(/\/$/, "");
      return tagName ? `#${tagName}` : "Tag";
    },
  },
  { match: (p: string) => p.startsWith("/post/"), getTitle: () => "Thread" },
  {
    match: (p: string) => p.startsWith("/@"),
    getTitle: () => "Profile",
  },
] as const;

const getHeaderTitle = (path: string) =>
  PATH_RULES.find((r) => r.match(path))?.getTitle(path) ?? "Memo";

const headerTitle = getHeaderTitle(currentPath);
---

<header>
    <div class="header-title">{headerTitle}</div>
</header>

<style>
    header {
        display: grid;
        grid-row: top / main-start;
        justify-items: center;
        width: 100%;
        padding-block: 1rem;
    }
    
    .header-title {
        font-size: var(--fs-xs);
        font-weight: var(--fw-semibold);
    }
</style>
