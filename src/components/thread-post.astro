---
import { Picture } from "astro:assets";
import { type CollectionEntry, render } from "astro:content";
import profileImage from "#/assets/profile.jpg";
import Avatar from "#/components/avatar.astro";
import LinkCard from "#/components/link-card.astro";
import PostHeader from "#/components/post-header.astro";
import { getImages } from "#/utils/image";
import type { MemoWithComments } from "#/utils/memo";

interface Props {
  memo: CollectionEntry<"memo">;
  asLink?: boolean;
  shouldUsePriority?: boolean;
  comments?: MemoWithComments[];
}

const {
  memo,
  asLink = true,
  shouldUsePriority = false,
  comments = [],
} = Astro.props;

const isComment = !!memo.data.comment;
const {
  id,
  author,
  createdAt,
  tag,
  images: imageFilenames,
  hideLinkCard,
} = memo.data;
const { Content, remarkPluginFrontmatter } = await render(memo);

const images = imageFilenames ? getImages(memo.id, imageFilenames) : [];

const firstExternalLink = remarkPluginFrontmatter?.firstExternalLink ?? null;
---

<div class:list={["post-container", { "is-comment": isComment }]}>
    <div class:list={["thread-wrapper", { "has-comments": comments.length > 0 }]}>
        {comments.length > 0 && (
            <span aria-hidden="true" class="avatar-line"></span>
        )}
        <div class="thread-avatar-column">
            <div class="post-avatar">
                <Avatar src={profileImage} alt={author} size={27} />
            </div>
        </div>

        <div class="thread-content-column">
            <article
                class="thread-post"
                data-clickable={asLink ? "true" : undefined}
                data-href={asLink ? `/post/${id}` : undefined}
            >
                <div class="post-content">
                    <PostHeader author={author} createdAt={createdAt} />
                    <div class="post-text">
                        <Content />
                    </div>
                    {tag && (
                        <div class="post-tags">
                            <a href={`/tag/${tag}`} class="tag-link">#{tag}</a>
                        </div>
                    )}
                    {images.length > 0 && (
                        <div class="post-images">
                            {images.map((image, index) => (
                                <Picture
                                    src={image}
                                    alt={`Image ${index + 1}`}
                                    formats={['avif']}
                                    widths={[320, 640, 1280]}
                                    sizes="(min-width: 640px) 640px, 100vw"
                                    class="post-image"
                                    {...(shouldUsePriority && { priority: true })}
                                />
                            ))}
                        </div>
                    )}
                    {!hideLinkCard && firstExternalLink && (
                        <div class="post-link-card">
                            <LinkCard href={firstExternalLink} />
                        </div>
                    )}
                </div>
            </article>
        </div>
    </div>

    {comments.length > 0 && (
        <div class="comments-container">
            {comments.map((commentWithChildren) => (
                <Astro.self
                    memo={commentWithChildren.memo}
                    comments={commentWithChildren.comments}
                />
            ))}
        </div>
    )}
</div>

<style>
    .post-container {
        border-bottom: 1px solid var(--c-gray);
    }

    .post-container.is-comment {
        border-bottom: none;
    }

    .thread-wrapper {
        position: relative;
        display: flex;
        gap: 0.65rem;
        padding: 1rem 0;
    }

    .thread-wrapper.has-comments {
        padding-bottom: 2rem;
    }

    .avatar-line {
        position: absolute;
        top: calc(1rem + 27px + 0.7rem);
        bottom: 1.5rem;
        left: 13.5px;
        margin-left: -1px;
        width: 2px;
        background-color: var(--c-gray);
        border-radius: 1px;
    }

    .comments-container {
        margin-top: -2rem;
    }

    .thread-avatar-column {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .thread-content-column {
        flex: 1;
        min-width: 0;
    }

    .thread-post[data-clickable="true"] {
        cursor: pointer;
    }

    .post-content {
        width: 100%;
    }

    .post-tags {
        margin-top: 0.5rem;
    }

    .tag-link {
        font-size: var(--fs-sm);
        color: var(--c-link);
        text-decoration: none;
    }

    .tag-link:hover {
        text-decoration: underline;
    }

    :global(.post-text p) {
        font-size: var(--fs-sm);
        line-height: var(--lh-sm);
        color: var(--c-text);
    }

    :global(.post-text p + p) {
        margin-top: 0.5rem;
    }

    :global(.post-text .external-link) {
        color: var(--c-link);
        text-decoration: none;
    }

    :global(.post-text .external-link:hover) {
        text-decoration: underline;
    }

    .post-images {
        display: grid;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    :global(.post-image) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 0 0 1px var(--c-gray);
    }

    .post-images:has(:only-child) :global(.post-image) {
        width: auto;
        height: auto;
        max-height: 430px;
    }

    .post-link-card {
        margin-top: 0.75rem;
    }
</style>
