---
import { Picture } from "astro:assets";
import { type CollectionEntry, render } from "astro:content";
import profileImage from "#/assets/profile.jpg";
import Avatar from "#/components/avatar.astro";
import PostHeader from "#/components/post-header.astro";
import { getImages } from "#/utils/image";

interface Props {
  memo: CollectionEntry<"memo">;
  asLink?: boolean;
  shouldUsePriority?: boolean;
}

const { memo, asLink = true, shouldUsePriority = false } = Astro.props;
const { id, author, createdAt, images: imageFilenames } = memo.data;
const { Content } = await render(memo);

const images = imageFilenames ? getImages(memo.id, imageFilenames) : [];
---

<article
    class="thread-post"
    data-clickable={asLink ? "true" : undefined}
    data-href={asLink ? `/post/${id}` : undefined}
>
    <div class="post-avatar">
        <Avatar src={profileImage} alt={author} size={27} />
    </div>
    <div class="post-content">
        <PostHeader author={author} createdAt={createdAt} />
        <div class="post-text">
            <Content />
        </div>
        {images.length > 0 && (
            <div class="post-images">
                {images.map((image, index) => (
                    <Picture
                        src={image}
                        alt={`Image ${index + 1}`}
                        formats={['avif']}
                        widths={[320, 640, 1280]}
                        sizes="(min-width: 640px) 640px, 100vw"
                        class="post-image"
                        {...(shouldUsePriority && { priority: true })}
                    />
                ))}
            </div>
        )}
    </div>
</article>

<style>
    .thread-post {
        display: flex;
        gap: 0.65rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--c-gray);
    }

    .thread-post[data-clickable="true"] {
        cursor: pointer;
    }

    .post-content {
        flex: 1;
        min-width: 0;
    }

    :global(.post-text p) {
        font-size: var(--fs-sm);
        line-height: var(--lh-sm);
        color: var(--c-text);
    }

    :global(.post-text p + p) {
        margin-top: 0.5rem;
    }

    .post-images {
        display: grid;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    :global(.post-image) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 0 0 1px var(--c-gray);
    }

    .post-images:has(:only-child) :global(.post-image) {
        width: auto;
        height: auto;
        max-height: 430px;
    }
</style>
