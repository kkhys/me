---
import { type CollectionEntry, render } from "astro:content";
import profileImage from "#/assets/profile.jpg";
import Avatar from "#/components/avatar.astro";
import PostHeader from "#/components/post-header.astro";

export interface Props {
  memo: CollectionEntry<"memo">;
}

const { memo } = Astro.props;
const { id, author, createdAt } = memo.data;
const { Content } = await render(memo);
---

<a href={`/${id}`} class="thread-post">
    <div class="post-avatar">
        <Avatar src={profileImage} alt={author} />
    </div>
    <div class="post-content">
        <PostHeader author={author} createdAt={createdAt} />
        <div class="post-text">
            <Content />
        </div>
    </div>
</a>

<style>
    .thread-post {
        display: flex;
        gap: 0.75rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--c-gray);
    }

    .post-content {
        flex: 1;
        min-width: 0;
    }

    :global(.post-text p) {
        font-size: var(--fs-sm);
        line-height: var(--lh-sm);
        color: var(--c-text);
    }

    :global(.post-text p + p) {
        margin-top: 0.5rem;
    }
</style>
