---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  size?: number;
}

const { src, alt, size = 30 } = Astro.props;
---

<Image
  src={src}
  alt={alt}
  width={size}
  height={size}
  densities={[1.5, 2]}
  class="avatar"
/>

<style>
  .avatar {
    border-radius: 50%;
    object-fit: cover;
  }
</style>
