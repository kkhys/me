---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  size: number;
  link?: string;
}

const { src, alt, size, link } = Astro.props;
---

{link ? (
  <a href={link} class="avatar-link">
    <Image
      src={src}
      alt={alt}
      width={size}
      height={size}
      densities={[1.5, 2]}
      class="avatar"
    />
  </a>
) : (
  <Image
    src={src}
    alt={alt}
    width={size}
    height={size}
    densities={[1.5, 2]}
    class="avatar"
  />
)}

<style>
  .avatar-link {
    transition: opacity 0.15s ease;
  }

  .avatar-link:hover {
    opacity: 0.8;
  }

  .avatar {
    border-radius: 50%;
    object-fit: cover;
    outline: 1px solid var(--c-gray);
    outline-offset: -0.5px;
  }
</style>
