{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    ":timezone(Asia/Tokyo)",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["after 1am and before 6am"],
  "dependencyDashboard": true,
  "assignees": ["kkhys"],
  "labels": ["type: bump-version"],
  "assignAutomerge": true,
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "groupName": "DevDependencies",
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "groupName": "Dependencies (minor update)",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "groupName": "pnpm catalog (non-major)",
      "matchDepTypes": ["pnpm.catalog.default"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "groupName": "pnpm catalog (major)",
      "matchDepTypes": ["pnpm.catalog.default"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "groupName": "Expressive Code",
      "matchPackageNames": ["astro-expressive-code", "@expressive-code/**"],
      "automerge": true
    }
  ]
}
